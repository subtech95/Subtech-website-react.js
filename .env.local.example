# ── Subtech CMS (CRM public read API) ─────────────────────────────────────────
# Origin of the CRM that hosts /api/public/*. Change to http://localhost:3001
# while developing against a local CRM. Trailing slash is stripped automatically.
NEXT_PUBLIC_CMS_BASE_URL=https://crm.subtech.in

# ── Enquiry forwarding ────────────────────────────────────────────────────────
# Endpoint that POSTed enquiries are forwarded to (used by /api/enquiry).
# Defaults to `${NEXT_PUBLIC_CMS_BASE_URL}/api/public/leads` when unset.
# ENQUIRY_FORWARD_URL=https://crm.subtech.in/api/public/leads
