# ── Subtech CMS (CRM public read API) ─────────────────────────────────────────
# Origin of the CRM that hosts /api/public/*. Change to http://localhost:3001
# while developing against a local CRM. Trailing slash is stripped automatically.
NEXT_PUBLIC_CMS_BASE_URL=https://crm.subtech.in

# ── Enquiry forwarding ────────────────────────────────────────────────────────
# Origin of the CRM that receives website form submissions (used by /api/enquiry).
# The proxy POSTs JSON to:
#   ${ENQUIRY_FORWARD_BASE}/api/public/enquiries     (general enquiries)
#   ${ENQUIRY_FORWARD_BASE}/api/public/service-requests   (customer-care service requests)
# Defaults to https://crm.subtech.in when unset.
# ENQUIRY_FORWARD_BASE=https://crm.subtech.in
